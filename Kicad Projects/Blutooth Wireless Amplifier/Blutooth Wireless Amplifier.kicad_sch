	(text "- R24,R25 = 0Ω jumper → Configuration link.\nNote: Default = short. Optional: replace with resistor for tuning/filtering\n"
		(exclude_from_sim no)
		(at 130.81 243.84 0)
		(effects
			(font
				(size 2 2)
			)
		)
		(uuid "24fe9286-4324-46fb-a603-f13b29a344bb")
	)
	(text "Microphone Connection Options:\n\nSingle microphone (differential type):\nUse MIC+ and MIC- (one pair). Bias line powers the capsule, differential pair carries audio.\n\nTwo microphones (if design allows):\nUse MIC_BP/MIC_BN for one mic, MIC_AP/MIC_AN for another. Requires codec/preamp with two channels.\n\nSingle-ended microphone:\nConnect signal to MIC+ (BP or AP), tie MIC- to GND. Bias pin provides DC supply.\n"
		(exclude_from_sim no)
		(at 194.31 203.2 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "4f76ed69-7bdb-466a-af84-7d2372942e7b")
	)
	(text "Use 1% tolerance resistors for all 10k values; upgrade to 0.1% for premium audio."
		(exclude_from_sim no)
		(at 444.5 22.86 0)
		(effects
