				(size 2.54 2.54)
			)
		)
		(uuid "6c571b75-215f-4868-bd35-b6a2a41ea5c3")
	)
	(text "- R10, R23 (10k, 1%) → Voltage divider to create VREF (mid‑supply bias).\nNote: Use 1% tolerance for stable reference. Optional: 0.1% for premium audio\n"
		(exclude_from_sim no)
		(at 358.14 80.01 0)
		(effects
			(font
				(size 2 2)
			)
		)
		(uuid "8e72b163-bd7b-4248-895b-d147797ec0c1")
	)
